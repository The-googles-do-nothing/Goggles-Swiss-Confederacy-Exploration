<?xml version="1.0" encoding="utf-8"?>
<GameEffects xmlns="GameEffects">

	<Modifier id="MOD_KANTONALBANK_GOLD_ON_QUARTERS" collection="COLLECTION_CITY_PLOT_YIELDS" effect="EFFECT_PLOT_ADJUST_YIELD">
		<SubjectRequirements>
			<Requirement type="REQUIREMENT_PLOT_IS_QUARTER"/>
